# ============================================================
# OpenClaw AI Learning Assistant — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# ============================================================

# ─────────────────────────────────────────────
# Telegram Bot Configuration
# ─────────────────────────────────────────────
# Obtain your bot token from @BotFather on Telegram.
# 1. Open Telegram and search for @BotFather
# 2. Send /newbot and follow the prompts
# 3. Copy the HTTP API token provided
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# ─────────────────────────────────────────────
# LLM Provider Configuration
# ─────────────────────────────────────────────
# Choose your LLM provider: ollama, openai, anthropic, google
LLM_PROVIDER=ollama

# Model name to use (e.g., llama3:8b, gpt-4o, claude-3-sonnet)
LLM_MODEL=llama3:8b

# Ollama server URL (only needed if using Ollama)
# When running with Docker Compose, use the service name: http://ollama:11434
# When running locally, use: http://localhost:11434
OLLAMA_BASE_URL=http://ollama:11434

# OpenAI API Key (only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# Anthropic API Key (only needed if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# Google API Key (only needed if LLM_PROVIDER=google)
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# ─────────────────────────────────────────────
# Web Search Configuration
# ─────────────────────────────────────────────
# Search provider: duckduckgo (default, no key needed), searxng, brave
WEB_SEARCH_PROVIDER=duckduckgo

# SearXNG instance URL (only needed if WEB_SEARCH_PROVIDER=searxng)
SEARXNG_BASE_URL=http://searxng:8080

# Brave Search API Key (only needed if WEB_SEARCH_PROVIDER=brave)
BRAVE_SEARCH_API_KEY=YOUR_BRAVE_SEARCH_API_KEY_HERE

# ─────────────────────────────────────────────
# Gateway Configuration
# ─────────────────────────────────────────────
# Port for the OpenClaw gateway web UI
GATEWAY_PORT=18789

# Log level: debug, info, warn, error
LOG_LEVEL=info

# ─────────────────────────────────────────────
# Timezone (default for cron jobs)
# ─────────────────────────────────────────────
# Default timezone for scheduled tasks (IANA format)
# This is overridden per-user by the onboarding flow
DEFAULT_TIMEZONE=UTC
